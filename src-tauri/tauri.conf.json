{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ti",
  "identifier": "com.ti.app",
  "version": "1.0.0",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "终端验证工具",
        "width": 900,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "Terminal Verification Tool",
      "args": [
        {
          "name": "command",
          "short": "c",
          "takesValue": true,
          "description": "Command to execute"
        },
        {
          "name": "verbose",
          "short": "v",
          "description": "Verbose output"
        }
      ]
    }
  },
  "bundle": {
    "active": false
  }
}
